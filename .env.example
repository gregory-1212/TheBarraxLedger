# TheBarraxLedger — copy to .env.local and fill in real values.
# NEVER commit .env.local — it's gitignored.
#
# In the production Codespace, CRM Supabase keys are exported as user-secrets
# and would otherwise override these via process.env. The dev/build/start
# npm scripts route through scripts/with-env.sh which sources .env.local
# with `set -a` so this file's values always win.

# ── Supabase ────────────────────────────────────────────────────────────
# Settings → API in the Ledger Supabase project
# (https://supabase.com/dashboard/project/owlslturwizhutsiyhjd)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# The "anon / publishable" key. Same value goes in both env vars below —
# legacy ANON_KEY name is kept for tooling that hasn't migrated; the
# Supabase client code reads the PUBLISHABLE_KEY name.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# The "service_role / secret" key — server-only, bypasses RLS. Same value
# goes in both env vars; SUPABASE_SECRET_KEY is the new name, _SERVICE_ROLE_
# is the legacy name.
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
# Settings → Database → "Database password" in the Supabase project. Used
# only by scripts/run-ddl.mjs to connect via the IPv4 pooler for DDL runs;
# the app itself talks to Supabase via the REST API and doesn't need it.
SUPABASE_DB_PASSWORD=

# ── App-level ───────────────────────────────────────────────────────────
# Base URL for auth callbacks (magic-link emailRedirectTo). For local
# dev, use the dev port (3020). Production deploy reads this from Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3020

# ── Year-end 1099-NEC payer info (LED-28) ───────────────────────────────
# The Barrax LLC info that prefills the payer block in the IRIS CSV
# export. Optional: if unset, those columns are blank and the CPA fills
# them in during filing. Set in Vercel for the live deploy.
LEDGER_PAYER_NAME=
LEDGER_PAYER_TIN=
LEDGER_PAYER_ADDRESS_LINE1=
LEDGER_PAYER_ADDRESS_LINE2=
LEDGER_PAYER_CITY=
LEDGER_PAYER_STATE=
LEDGER_PAYER_ZIP=
LEDGER_PAYER_COUNTRY_CODE=US
LEDGER_PAYER_PHONE=

# ── Pending features (set when wiring) ──────────────────────────────────
# LED-38: AES-256-GCM key for vendors.tax_id_encrypted. 32 bytes (64
# hex chars). Without this the TIN reveal endpoint + year-end CSV TIN
# decryption are no-ops.
# TAX_ID_ENCRYPTION_KEY=

# LED-22..25, LED-55: Receipt OCR via Claude Vision. Without this the
# receipts upload pipeline can't read text from images.
# ANTHROPIC_API_KEY=
